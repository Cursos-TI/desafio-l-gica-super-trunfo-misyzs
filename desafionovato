#include <stdio.h>

int main() {
    char estadoA, estadoB;
    char codigoA[4], codigoB[4];
    char cidadeA[16], cidadeB[16];
    
    int populacaoA, populacaoB;
    
    int pontosA, pontosB;

    float areaA, areaB;
    float pibA, pibB;
    float densidadeA, densidadeB;
    float percapitaA, percapitaB;
    float poderA, poderB;

    // Primeira Carta

    printf("Informações da primeira carta\n");

    printf("Digite a inicial do estado: ");
    scanf(" %c", &estadoA);

    printf("Digite o código da carta (Letra inicial seguida de 2 números): ");
    scanf(" %s", codigoA);

    getchar(); // Usado para limpar cache do \n do "fgets" e não causar bugs

    printf("Digite o nome de uma cidade do estado: ");
    fgets(cidadeA, 16, stdin); // "fgets" Usado para digitar caracteres que o "scanf" nao identifica, como o espaço entre a cidade São Paulo
    
    printf("Digite o número de habitantes: ");
    scanf(" %d", &populacaoA);

    printf("Digite o número de pontos turisticos dessa cidade: ");
    scanf(" %d", &pontosA);

    printf("Digite a área da cidade em quilômetros quadrados: ");
    scanf(" %f", &areaA);

    printf("Digite o PIB da cidade: ");
    scanf(" %f", &pibA);

    // Segunda Carta

    printf("\nInformações da segunda carta\n");

    printf("Digite a inicial do estado: ");
    scanf(" %c", &estadoB);

    printf("Digite o código da carta (Letra inicial seguida de 2 números): ");
    scanf(" %s", codigoB);

    getchar();

    printf("Digite o nome de uma cidade do estado: ");
    fgets(cidadeB, 16, stdin);

    printf("Digite o número de habitantes: ");
    scanf(" %d", &populacaoB);

    printf("Digite o número de pontos turisticos dessa cidade: ");
    scanf(" %d", &pontosB);

    printf("Digite a área da cidade em quilômetros quadrados: ");
    scanf(" %f", &areaB);

    printf("Digite o PIB da cidade: ");
    scanf(" %f", &pibB);

    // Exibição das duas cartas

    printf("\nCarta A\n");

    printf("Inicial do estado: %c\n", estadoA);
    printf("Código da carta: %s\n", codigoA);
    printf("Nome da cidade: %s\n", cidadeA);
    printf("Número de habitantes da cidade: %d\n", populacaoA);
    printf("Número de pontos turisticos: %d\n", pontosA);
    printf("Área da cidade: %.2f\n", areaA);
    printf("PIB da cidade: %.2f\n", pibA);

    densidadeA = populacaoA / areaA;
    printf("A densidade populacional é de: %.2f\n", densidadeA);

    percapitaA = pibA / populacaoA;
    printf("O PIB per Capita é de: %.2f\n", percapitaA);

    printf("\nCarta B\n");

    printf("Inicial do estado: %c\n", estadoB);
    printf("Código da carta: %s\n", codigoB);
    printf("Nome da cidade: %s\n", cidadeB);
    printf("Número de habitantes da cidade: %d\n", populacaoB);
    printf("Número de pontos turisticos: %d\n", pontosB);
    printf("Área da cidade: %.2f\n", areaB);
    printf("PIB da cidade: %.2f\n", pibB);

    densidadeB = populacaoB / areaB;
    printf("A densidade populacional é de: %.2f\n", densidadeB);

    percapitaB = pibB / populacaoB;
    printf("O PIB per Capita é de: %.2f\n", percapitaB);

    // Comparação entre as duas cartas

    printf("\nComparação entre cartas\n");

    printf("Densidade populacional da carta A: %.2f\n", densidadeA);
    printf("Densidade populacional da carta B: %.2f\n", densidadeB);

    if (densidadeA > densidadeB) {
        printf("A carta A perdeu.");
    }

    else {
        printf("A carta A venceu!");
    }

    return 0;
}
